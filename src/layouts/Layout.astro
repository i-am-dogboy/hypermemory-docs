---
import { ClientRouter } from 'astro:transitions';
import { AssistantSheet, AssistantProvider } from '../components/Assistant';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'HyperMemory Docs', description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preload" href="/fonts/CircularXX-Book.otf" as="font" type="font/otf" crossorigin />
    <link rel="preload" href="/fonts/CircularXX-Medium.otf" as="font" type="font/otf" crossorigin />
    <link rel="preload" href="/fonts/CircularXX-Bold.otf" as="font" type="font/otf" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <ClientRouter />
  </head>
  <body>
    <AssistantProvider client:only="react" />
    <div class="flex antialiased">
      <div class="flex-1 min-w-0 max-w-[1400px] mx-auto w-full">
        <slot />
      </div>
      <AssistantSheet client:only="react" transition:persist />
    </div>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    overscroll-behavior-y: none;
  }

  ::view-transition-old(*),
  ::view-transition-new(*),
  ::view-transition-group(*) {
    animation-duration: 0s !important;
  }
</style>
